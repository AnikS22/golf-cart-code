<!--
  gem_e4_preview.urdf.xacro
  =========================
  Standalone preview URDF for offline visualization on macOS / Foxglove
  / web URDF viewers. NOT used by the sim or the real cart. Just for
  "what does the digital twin look like."

  Differs from gem_e4_robot.urdf.xacro in that it does NOT include the
  upstream gem_description chassis package — instead it ships a stub
  cart body so xacro can fully expand without ROS environment.

  Regenerate the flat URDF with: bin/preview_urdf.sh
-->
<robot name="gem_e4_preview">
  <!-- approx half body width to A/B pillar -->
  <!-- 5 mph Phase 1 cap -->
  <!-- ====================================================================
       FRAME ORIGIN (REP-103: X forward, Y left, Z up)

       base_link is at ground level, midway between the rear axle (X=0)
       and the vehicle center. Cartagena's URDF places base_link near
       vehicle center; we keep that convention.

       base_footprint = base_link projected to the ground plane.
       ==================================================================== -->
  <!-- Rear axle is at X = -WHEELBASE/2, front axle at X = +WHEELBASE/2 -->
  <!-- +45° -->
  <!-- -45° -->
  <!-- +135° -->
  <!-- -135° -->
  <!-- 180°, facing aft -->
  <!-- baseline = ~1.0 m which gives good heading accuracy -->
  <!-- ====================================================================
       SENSOR SPECS (FOV, rate, range, noise)

       Pulled from manufacturer datasheets in
       Hardware/OneDrive_1_5-1-2026/Motor/ and elsewhere.
       ==================================================================== -->
