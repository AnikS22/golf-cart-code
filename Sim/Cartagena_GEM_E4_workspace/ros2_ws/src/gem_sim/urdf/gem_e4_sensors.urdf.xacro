<?xml version="1.0"?>
<!--
  gem_e4_sensors.urdf.xacro

  Additive sensor stack for the GEM E4 digital twin. Reads ALL geometry
  and sensor specs from cart_parameters.xacro — never hard-codes a value
  that exists there. Single source of truth.

  Include from a top-level robot xacro:

    <xacro:include filename="$(find gem_sim)/urdf/cart_parameters.xacro"/>
    <xacro:include filename="$(find gem_sim)/urdf/gem_e4_sensors.urdf.xacro"/>
    <xacro:gem_e4_sensors parent="base_link"/>

  Coordinates: ROS REP-103 (X forward, Y left, Z up).
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Helper: simple box-shaped sensor placeholder + frame -->
  <xacro:macro name="sensor_box" params="name parent xyz rpy size:='0.05 0.05 0.05' rgba:='0.1 0.1 0.1 1.0'">
    <link name="${name}_link">
      <visual>
        <geometry><box size="${size}"/></geometry>
        <material name="${name}_mat"><color rgba="${rgba}"/></material>
      </visual>
      <collision>
        <geometry><box size="${size}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="1e-4" iyy="1e-4" izz="1e-4" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${name}_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${name}_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>
  </xacro:macro>

  <xacro:macro name="gem_e4_sensors" params="parent:='base_link'">

    <!-- ============ LiDAR — Livox Mid-360 ============ -->
    <xacro:sensor_box name="lidar"
                      parent="${parent}"
                      xyz="${EXT_LIDAR_X} ${EXT_LIDAR_Y} ${EXT_LIDAR_Z}"
                      rpy="${EXT_LIDAR_R} ${EXT_LIDAR_P} ${EXT_LIDAR_YAW}"
                      size="0.065 0.065 0.060"
                      rgba="0.15 0.15 0.15 1"/>
    <gazebo reference="lidar_link">
      <sensor type="gpu_lidar" name="livox_mid360">
        <update_rate>${LIDAR_RATE_HZ}</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>${LIDAR_H_SAMPLES}</samples>
              <resolution>1</resolution>
              <min_angle>${LIDAR_H_MIN_RAD}</min_angle>
              <max_angle>${LIDAR_H_MAX_RAD}</max_angle>
            </horizontal>
            <vertical>
              <samples>${LIDAR_V_SAMPLES}</samples>
              <resolution>1</resolution>
              <min_angle>${LIDAR_V_MIN_RAD}</min_angle>
              <max_angle>${LIDAR_V_MAX_RAD}</max_angle>
            </vertical>
          </scan>
          <range>
            <min>${LIDAR_RANGE_MIN_M}</min>
            <max>${LIDAR_RANGE_MAX_M}</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>${LIDAR_NOISE_STDDEV}</stddev>
          </noise>
        </lidar>
        <topic>${TOPIC_LIDAR}</topic>
        <gz_frame_id>lidar_link</gz_frame_id>
        <always_on>true</always_on>
        <visualize>false</visualize>
      </sensor>
    </gazebo>

    <!-- ============ ZED 2i — front stereo ============ -->
    <xacro:sensor_box name="zed2i_camera"
                      parent="${parent}"
                      xyz="${EXT_ZED2I_X} ${EXT_ZED2I_Y} ${EXT_ZED2I_Z}"
                      rpy="${EXT_ZED2I_R} ${EXT_ZED2I_P} ${EXT_ZED2I_YAW}"
                      size="0.18 0.03 0.03"
                      rgba="0.1 0.1 0.1 1"/>
    <gazebo reference="zed2i_camera_link">
      <sensor name="zed2i_left" type="camera">
        <update_rate>${ZED2I_RATE_HZ}</update_rate>
        <camera>
          <horizontal_fov>${ZED2I_HFOV_RAD}</horizontal_fov>
          <image><width>${ZED2I_WIDTH_PX}</width><height>${ZED2I_HEIGHT_PX}</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>100</far></clip>
        </camera>
        <topic>${TOPIC_ZED2I_LEFT}</topic>
        <gz_frame_id>zed2i_camera_link</gz_frame_id>
        <always_on>true</always_on>
      </sensor>
      <sensor name="zed2i_depth" type="depth_camera">
        <update_rate>15</update_rate>
        <camera>
          <horizontal_fov>${ZED2I_HFOV_RAD}</horizontal_fov>
          <image><width>${ZED2I_WIDTH_PX}</width><height>${ZED2I_HEIGHT_PX}</height></image>
          <clip><near>${ZED2I_RANGE_NEAR_M}</near><far>${ZED2I_RANGE_FAR_M}</far></clip>
        </camera>
        <topic>${TOPIC_ZED2I_DEPTH}</topic>
        <gz_frame_id>zed2i_camera_link</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- ============ Leopard IMX390 GMSL front mono ============ -->
    <xacro:sensor_box name="front_cam"
                      parent="${parent}"
                      xyz="${EXT_FRONTCAM_X} ${EXT_FRONTCAM_Y} ${EXT_FRONTCAM_Z}"
                      rpy="${EXT_FRONTCAM_R} ${EXT_FRONTCAM_P} ${EXT_FRONTCAM_YAW}"
                      size="0.05 0.04 0.04"
                      rgba="0.05 0.05 0.05 1"/>
    <gazebo reference="front_cam_link">
      <sensor name="front_cam_imx390" type="camera">
        <update_rate>${FRONTCAM_RATE_HZ}</update_rate>
        <camera>
          <horizontal_fov>${FRONTCAM_HFOV_RAD}</horizontal_fov>
          <image><width>${FRONTCAM_WIDTH_PX}</width><height>${FRONTCAM_HEIGHT_PX}</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>200</far></clip>
        </camera>
        <topic>${TOPIC_FRONTCAM}</topic>
        <gz_frame_id>front_cam_link</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- ============ Corner cameras (4× e-CAM130 GMSL, 120° FOV) ============ -->
    <xacro:macro name="corner_cam" params="name xyz yaw topic">
      <xacro:sensor_box name="${name}"
                        parent="${parent}"
                        xyz="${xyz}"
                        rpy="0 0 ${yaw}"
                        size="0.04 0.04 0.04"
                        rgba="0.05 0.05 0.05 1"/>
      <gazebo reference="${name}_link">
        <sensor name="${name}_imx377" type="camera">
          <update_rate>${CORNERCAM_RATE_HZ}</update_rate>
          <camera>
            <horizontal_fov>${CORNERCAM_HFOV_RAD}</horizontal_fov>
            <image><width>${CORNERCAM_WIDTH_PX}</width><height>${CORNERCAM_HEIGHT_PX}</height><format>R8G8B8</format></image>
            <clip><near>0.1</near><far>50</far></clip>
          </camera>
          <topic>${topic}</topic>
          <gz_frame_id>${name}_link</gz_frame_id>
        </sensor>
      </gazebo>
    </xacro:macro>

    <xacro:corner_cam name="cam_fl" xyz="${EXT_CAM_FL_X} ${EXT_CAM_FL_Y} ${EXT_CAM_FL_Z}" yaw="${EXT_CAM_FL_YAW}" topic="${TOPIC_CAM_FL}"/>
    <xacro:corner_cam name="cam_fr" xyz="${EXT_CAM_FR_X} ${EXT_CAM_FR_Y} ${EXT_CAM_FR_Z}" yaw="${EXT_CAM_FR_YAW}" topic="${TOPIC_CAM_FR}"/>
    <xacro:corner_cam name="cam_rl" xyz="${EXT_CAM_RL_X} ${EXT_CAM_RL_Y} ${EXT_CAM_RL_Z}" yaw="${EXT_CAM_RL_YAW}" topic="${TOPIC_CAM_RL}"/>
    <xacro:corner_cam name="cam_rr" xyz="${EXT_CAM_RR_X} ${EXT_CAM_RR_Y} ${EXT_CAM_RR_Z}" yaw="${EXT_CAM_RR_YAW}" topic="${TOPIC_CAM_RR}"/>

    <!-- ============ ZED Mini rear stereo ============ -->
    <xacro:sensor_box name="zed_mini_camera"
                      parent="${parent}"
                      xyz="${EXT_ZEDMINI_X} ${EXT_ZEDMINI_Y} ${EXT_ZEDMINI_Z}"
                      rpy="${EXT_ZEDMINI_R} ${EXT_ZEDMINI_P} ${EXT_ZEDMINI_YAW}"
                      size="0.12 0.025 0.025"
                      rgba="0.1 0.1 0.1 1"/>
    <gazebo reference="zed_mini_camera_link">
      <sensor name="zed_mini_left" type="camera">
        <update_rate>${ZEDMINI_RATE_HZ}</update_rate>
        <camera>
          <horizontal_fov>${ZEDMINI_HFOV_RAD}</horizontal_fov>
          <image><width>${ZEDMINI_WIDTH_PX}</width><height>${ZEDMINI_HEIGHT_PX}</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>50</far></clip>
        </camera>
        <topic>${TOPIC_ZEDMINI}</topic>
        <gz_frame_id>zed_mini_camera_link</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- ============ GNSS antennas (moving baseline pair) ============ -->
    <xacro:sensor_box name="gnss_antenna1"
                      parent="${parent}"
                      xyz="${EXT_GNSS1_X} ${EXT_GNSS1_Y} ${EXT_GNSS1_Z}"
                      rpy="0 0 0"
                      size="0.08 0.08 0.02"
                      rgba="0.0 0.4 0.0 1"/>
    <xacro:sensor_box name="gnss_antenna2"
                      parent="${parent}"
                      xyz="${EXT_GNSS2_X} ${EXT_GNSS2_Y} ${EXT_GNSS2_Z}"
                      rpy="0 0 0"
                      size="0.08 0.08 0.02"
                      rgba="0.0 0.4 0.0 1"/>
    <gazebo reference="gnss_antenna1_link">
      <sensor name="gnss_rover" type="gps">
        <update_rate>${GNSS_RATE_HZ}</update_rate>
        <topic>${TOPIC_GNSS_FIX}</topic>
        <gz_frame_id>gnss_antenna1_link</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- ============ IMU — VectorNav VN-100
         Link name is vn100_link (not imu_link) to avoid collision with
         the upstream gem-simulator chassis URDF which has its own
         imu_link. ============ -->
    <xacro:sensor_box name="vn100"
                      parent="${parent}"
                      xyz="${EXT_IMU_X} ${EXT_IMU_Y} ${EXT_IMU_Z}"
                      rpy="${EXT_IMU_R} ${EXT_IMU_P} ${EXT_IMU_YAW}"
                      size="0.05 0.04 0.02"
                      rgba="0.4 0.0 0.0 1"/>
    <gazebo reference="vn100_link">
      <sensor name="vn100_imu" type="imu">
        <update_rate>${IMU_RATE_HZ}</update_rate>
        <topic>${TOPIC_IMU}</topic>
        <gz_frame_id>vn100_link</gz_frame_id>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>${IMU_GYRO_NOISE_STDDEV}</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>${IMU_GYRO_NOISE_STDDEV}</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>${IMU_GYRO_NOISE_STDDEV}</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>${IMU_ACCEL_NOISE_STDDEV}</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>${IMU_ACCEL_NOISE_STDDEV}</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>${IMU_ACCEL_NOISE_STDDEV}</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>
    </gazebo>

  </xacro:macro>
</robot>
