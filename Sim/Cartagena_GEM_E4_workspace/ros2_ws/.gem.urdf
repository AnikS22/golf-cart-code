    <origin rpy="1.5708 0 3.1416" xyz="0.02 0.42 0"/>
    <parent link="top_rack_link"/>
    <child link="os_sensor"/>
  </joint>
  <link name="os_sensor">
    <inertial>
      <mass value="0.33"/>
      <origin rpy="0 0 0" xyz="0 0 0.0365"/>
      <inertia ixx="0.000241148" ixy="0" ixz="0" iyy="0.000241148" iyz="0" izz="0.000264"/>
    </inertial>
    <collision name="base_collision">
      <origin rpy="0 0 0" xyz="0 0 0.0365"/>
      <geometry>
        <cylinder length="0.073" radius="0.04"/>
      </geometry>
    </collision>
