  <gazebo>
    <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
      <legacyModeNS>true</legacyModeNS>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
    </plugin>
  </gazebo>
  <!--
    Planar move drive: kinematic body translation from /cmd_vel, publishes /odom.
    Wheels won't spin visually (no joint coupling) but the cart body follows the
    twist command exactly. Chosen over ackermann_drive because Gazebo's fixed-joint
    reduction on this URDF mangles the wheel joint names the ackermann plugin needs.
  -->
  <gazebo>
    <plugin filename="libgazebo_ros_planar_move.so" name="planar_move">
      <ros>
        <namespace>/</namespace>
      </ros>
      <update_rate>50</update_rate>
      <publish_rate>50</publish_rate>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>
  <!-- ***************************** camera ***************************** -->
  <gazebo reference="front_single_camera_link">
    <sensor name="front_single_camera_sensor" type="camera">
      <update_rate>23.0</update_rate>
      <camera>
        <!--
      <camera name="front_single_camera"> 
      -->
        <horizontal_fov>1.5707963</horizontal_fov>
        <image>
          <width>1152</width>
          <height>720</height>
          <!--
          <width>960</width>
          <height>540</height>
          -->
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_camera.so" name="front_single_camera_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>oak/rgb</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>front_single_camera_link</frameName>
        <hackBaseline>0.07</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
  <!-- ***************************** IMU ***************************** -->
  <gazebo>
    <plugin filename="libgazebo_ros_imu.so" name="imu_plugin">
      <alwaysOn>true</alwaysOn>
      <bodyName>IMU_link</bodyName>
      <frameName>IMU_link</frameName>
      <topicName>imu</topicName>
      <serviceName>imu_service</serviceName>
      <gaussianNoise>0.0</gaussianNoise>
      <updateRate>50.0</updateRate>
    </plugin>
  </gazebo>
  <!-- ***************************** GPS ***************************** -->
  <gazebo>
    <plugin filename="libhector_gazebo_ros_gps.so" name="gazebo_ros_gps">
      <updateRate>20.0</updateRate>
      <bodyName>GPS_link</bodyName>
      <frameId>GPS_link</frameId>
      <topicName>/gps/fix</topicName>
      <velocityTopicName>/gps/fix_velocity</velocityTopicName>
      <useWorldSphericalCoordinates>true</useWorldSphericalCoordinates>
      <offset>0 0 0</offset>
      <drift>0.001 0.001 0.001</drift>
      <gaussianNoise>0.05 0.05 0.05</gaussianNoise>
      <velocityDrift>0.001 0.001 0.001</velocityDrift>
      <velocityGaussianNoise>0.5 0.5 0.5</velocityGaussianNoise>
      <!-- <drift>0.001 0.001 0.001</drift> -->
      <!-- <gaussianNoise>0.01 0.01 0.01</gaussianNoise> -->
      <!-- <velocityDrift>0 0 0</velocityDrift>-->
      <!-- <velocityGaussianNoise>0.05 0.05 0.05</velocityGaussianNoise> -->
    </plugin>
  </gazebo>
  <!-- ***************************** Front Sonar ***************************** -->
  <gazebo reference="front_sonar_link">
    <sensor name="front_sonar_sensor" type="ray">
      <always_on>true</always_on>
      <update_rate>20</update_rate>
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>2</samples>
            <resolution>1</resolution>
            <min_angle>-28</min_angle>
            <max_angle>28</max_angle>
          </horizontal>
          <vertical>
            <samples>2</samples>
            <resolution>1</resolution>
            <min_angle>-28</min_angle>
            <max_angle>28</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>5</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin filename="libhector_gazebo_ros_sonar.so" name="gazebo_ros_sonar_controller">
        <gaussianNoise>0.005</gaussianNoise>
        <topicName>/front_sonar_distance</topicName>
        <frameId>front_sonar_link</frameId>
      </plugin>
    </sensor>
  </gazebo>
  <!-- ***************************** Rear Sonar ***************************** -->
  <gazebo reference="rear_sonar_link">
    <sensor name="rear_sonar_sensor" type="ray">
      <always_on>true</always_on>
      <update_rate>20</update_rate>
      <pose>0 0 0 0 0 0</pose>
      <visualize>false</visualize>
      <ray>
        <scan>
          <horizontal>
            <samples>2</samples>
            <resolution>1</resolution>
            <min_angle>-28</min_angle>
            <max_angle>28</max_angle>
          </horizontal>
          <vertical>
            <samples>2</samples>
            <resolution>1</resolution>
            <min_angle>-28</min_angle>
            <max_angle>28</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.3</min>
          <max>5</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin filename="libhector_gazebo_ros_sonar.so" name="gazebo_ros_sonar_controller">
        <gaussianNoise>0.005</gaussianNoise>
        <topicName>/rear_sonar_distance</topicName>
        <frameId>rear_sonar_link</frameId>
      </plugin>
    </sensor>
  </gazebo>
  <!-- ***************************** stereo camera ***************************** -->
  <gazebo reference="stereo_camera_link">
    <sensor name="stereo_camera" type="multicamera">
      <update_rate>30.0</update_rate>
      <camera name="left">
        <horizontal_fov>1.5707963</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <camera name="right">
        <pose>0 -0.07 0 0 0 0</pose>
        <horizontal_fov>1.5707963</horizontal_fov>
        <image>
          <width>800</width>
          <height>600</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <plugin filename="libgazebo_ros_multicamera.so" name="stereo_camera_controller">
        <alwaysOn>true</alwaysOn>
        <updateRate>0.0</updateRate>
        <cameraName>stereo/camera</cameraName>
        <imageTopicName>image_raw</imageTopicName>
        <cameraInfoTopicName>camera_info</cameraInfoTopicName>
        <frameName>stereo_camera_link</frameName>
        <!--<rightFrameName>right_camera_optical_frame</rightFrameName>-->
        <!-- <hackBaseline>0.07</hackBaseline> -->
        <hackBaseline>0.5</hackBaseline>
        <distortionK1>0.0</distortionK1>
        <distortionK2>0.0</distortionK2>
        <distortionK3>0.0</distortionK3>
        <distortionT1>0.0</distortionT1>
        <distortionT2>0.0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>
